# Core
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
PORT=8787

# Production origin and persistent storage
PUBLIC_BASE_URL=http://localhost:8787
MCP_RESOURCE_URL=http://localhost:8787
DB_PATH=
BACKUP_DIR=
BACKUP_RETENTION_DAYS=14

# Built-in single-user authentication — required in production
SINGLE_USER_EMAIL=
SINGLE_USER_PASSWORD=
# Stable random value with at least 32 characters. Do not rotate while ChatGPT is connected.
OAUTH_SIGNING_SECRET=
MCP_REQUIRED_SCOPES=operations:read operations:write
SESSION_TTL_HOURS=8
RATE_LIMIT_PER_MINUTE=240
AGENT_RATE_LIMIT_PER_MINUTE=30
LOGIN_RATE_LIMIT_PER_MINUTE=10

# Development compatibility only. Production refuses to start when this is set.
AUTH_TOKEN=

# Google (Gmail send, Calendar, Drive) — create OAuth credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Eventbrite live ticket sync
EVENTBRITE_TOKEN=
EVENTBRITE_EVENT_ID=

# Buffer content queue
BUFFER_TOKEN=
BUFFER_PROFILE_ID=

# Set to "off" to disable the background scheduler
SCHEDULER=
